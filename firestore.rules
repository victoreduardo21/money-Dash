rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.email == "eduardopontesdias@outlook.com";
    }

    function isAdmin() {
      return isSuperAdmin() || 
        (isSignedIn() && 
         exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Refined read rule for list queries
    // Normal users check their own data first (fast, matches query filter)
    // SuperAdmins check token (fast, no DB read)
    // Admins check DB (slower)
    function canReadDoc() {
      return isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        request.auth.token.email == "eduardopontesdias@outlook.com" ||
        isAdmin()
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }
    
    function isValidUser(data) {
      return data.keys().hasAll(['name', 'email', 'plan']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.email is string && data.email.matches('^.+@.+$') &&
             data.plan in ['FREE', 'PRO', 'VIP'] &&
             (data.phone == null || (data.phone is string && data.phone.size() < 25)) &&
             (data.cpf == null || (data.cpf is string && data.cpf.size() < 25)) &&
             (data.subscriptionStatus == null || data.subscriptionStatus in ['ACTIVE', 'PENDING', 'OVERDUE', 'INACTIVE']) &&
             (data.role == null || data.role in ['admin', 'user']) &&
             (data.billingCycle == null || data.billingCycle in ['MONTHLY', 'ANNUAL']) &&
             (data.phoneVerified == null || data.phoneVerified is bool) &&
             (data.overdraftLimit == null || data.overdraftLimit is number) &&
             (data.createdAt == null || data.createdAt is string) &&
             (data.avatar == null || data.avatar is string);
    }
    
    function isValidTransaction(data) {
      return data.keys().hasAll(['description', 'amount', 'currency', 'date', 'type', 'userId', 'category']) &&
             data.description is string && data.description.size() > 0 && data.description.size() < 255 &&
             data.category is string && data.category.size() < 100 &&
             data.amount is number &&
             data.currency in ['BRL', 'USD'] &&
             data.type in ['Receita', 'Despesa'] &&
             data.userId == request.auth.uid;
    }
    
    function isValidInvestment(data) {
      return data.keys().hasAll(['name', 'initialAmount', 'currentValue', 'currency', 'userId']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 255 &&
             data.initialAmount is number &&
             data.currentValue is number &&
             data.currency in ['BRL', 'USD'] &&
             data.userId == request.auth.uid;
    }
    
    function isValidCalendarEvent(data) {
      return data.keys().hasAll(['description', 'date', 'done', 'userId']) &&
             data.description is string && data.description.size() > 0 && data.description.size() < 255 &&
             data.date is string &&
             data.done is bool &&
             data.userId == request.auth.uid;
    }

    function isValidCreditCard(data) {
      return data.keys().hasAll(['name', 'limit', 'closingDay', 'dueDay', 'currency', 'userId']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.limit is number &&
             data.closingDay is int && data.closingDay >= 1 && data.closingDay <= 31 &&
             data.dueDay is int && data.dueDay >= 1 && data.dueDay <= 31 &&
             data.currency in ['BRL', 'USD'] &&
             data.userId == request.auth.uid;
    }

    function isValidCreditTransaction(data) {
      return data.keys().hasAll(['cardId', 'description', 'amount', 'totalInstallments', 'date', 'userId', 'category']) &&
             data.description is string && data.description.size() > 0 && data.description.size() < 255 &&
             data.amount is number &&
             data.totalInstallments is int &&
             data.category is string &&
             (data.status == null || data.status in ['PENDING', 'PAID']) &&
             (data.paymentDate == null || data.paymentDate is string) &&
             data.userId == request.auth.uid;
    }

    function isValidAiConversation(data) {
      return data.keys().hasAll(['messages', 'userId', 'lastUpdate']) &&
             data.userId == request.auth.uid &&
             data.messages is list;
    }

    function isValidSubscription(data) {
      return data.keys().hasAll(['description', 'amount', 'currency', 'dueDay', 'category', 'status', 'userId']) &&
             data.description is string && data.description.size() > 0 &&
             data.amount is number &&
             data.currency in ['BRL', 'USD'] &&
             data.dueDay is int && data.dueDay >= 1 && data.dueDay <= 31 &&
             data.status in ['ACTIVE', 'PAUSED'] &&
             data.userId == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /test/connection {
      allow read: if isSignedIn();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isSuperAdmin() || isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if (isOwner(userId) || isSuperAdmin() || isAdmin()) && isValidUser(incoming());
      allow delete: if isSuperAdmin() || isAdmin();
    }
    
    match /transactions/{transactionId} {
      allow read: if canReadDoc();
      allow create: if isSignedIn() && isValidTransaction(incoming());
      allow update: if isSignedIn() && (isDocOwner() || isAdmin()) && isValidTransaction(incoming());
      allow delete: if isSignedIn() && (isDocOwner() || isAdmin());
    }
    
    match /investments/{investmentId} {
      allow read: if canReadDoc();
      allow create: if isSignedIn() && isValidInvestment(incoming());
      allow update: if isSignedIn() && (isDocOwner() || isAdmin()) && isValidInvestment(incoming());
      allow delete: if isSignedIn() && (isDocOwner() || isAdmin());
    }
    
    match /calendar/{eventId} {
      allow read: if canReadDoc();
      allow create: if isSignedIn() && isValidCalendarEvent(incoming());
      allow update: if isSignedIn() && (isDocOwner() || isAdmin()) && isValidCalendarEvent(incoming());
      allow delete: if isSignedIn() && (isDocOwner() || isAdmin());
    }

    match /credit_cards/{cardId} {
      allow read: if canReadDoc();
      allow create: if isSignedIn() && isValidCreditCard(incoming());
      allow update: if isSignedIn() && (isDocOwner() || isAdmin()) && isValidCreditCard(incoming());
      allow delete: if isSignedIn() && (isDocOwner() || isAdmin());
    }

    match /credit_transactions/{txId} {
      allow read: if canReadDoc();
      allow create: if isSignedIn() && isValidCreditTransaction(incoming());
      allow update: if isSignedIn() && (isDocOwner() || isAdmin()) && isValidCreditTransaction(incoming());
      allow delete: if isSignedIn() && (isDocOwner() || isAdmin());
    }

    match /ai_conversations/{convId} {
      allow read: if isOwner(convId) || isAdmin();
      allow create: if isSignedIn() && isValidAiConversation(incoming());
      allow update: if (isOwner(convId) || isAdmin()) && isValidAiConversation(incoming());
      allow delete: if isOwner(convId) || isAdmin();
    }

    match /subscriptions/{subId} {
      allow read: if canReadDoc();
      allow create: if isSignedIn() && isValidSubscription(incoming());
      allow update: if isSignedIn() && (isDocOwner() || isAdmin()) && isValidSubscription(incoming());
      allow delete: if isSignedIn() && (isDocOwner() || isAdmin());
    }
  }
}
