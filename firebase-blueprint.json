{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "avatar": { "type": "string", "description": "Base64 encoded avatar image" },
        "phone": { "type": "string" },
        "cpf": { "type": "string" },
        "plan": { "type": "string", "enum": ["FREE", "PRO", "VIP"] },
        "billingCycle": { "type": "string", "enum": ["MONTHLY", "ANNUAL"] },
        "language": { "type": "string", "enum": ["pt-BR", "en-US"] },
        "subscriptionStatus": { "type": "string", "enum": ["ACTIVE", "PENDING", "OVERDUE"] }
      },
      "required": ["name", "email", "plan"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial transaction",
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string", "enum": ["BRL", "USD"] },
        "date": { "type": "string", "format": "date" },
        "type": { "type": "string", "enum": ["Receita", "Despesa"] },
        "category": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["description", "amount", "currency", "date", "type", "userId"]
    },
    "Investment": {
      "title": "Investment",
      "description": "Financial investment",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "initialAmount": { "type": "number" },
        "currentValue": { "type": "number" },
        "yieldRate": { "type": "number" },
        "currency": { "type": "string", "enum": ["BRL", "USD"] },
        "userId": { "type": "string" }
      },
      "required": ["name", "initialAmount", "currentValue", "currency", "userId"]
    },
    "CalendarEvent": {
      "title": "CalendarEvent",
      "description": "Task or reminder",
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "done": { "type": "boolean" },
        "userId": { "type": "string" }
      },
      "required": ["description", "date", "done", "userId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile document"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Financial transactions collection"
    },
    "/investments/{investmentId}": {
      "schema": "Investment",
      "description": "Financial investments collection"
    },
    "/calendar/{eventId}": {
      "schema": "CalendarEvent",
      "description": "Calendar events collection"
    }
  }
}
